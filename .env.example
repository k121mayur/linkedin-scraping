# LinkedIn credentials
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# Playwright
PLAYWRIGHT_HEADLESS=true
MAX_DETAIL_CONCURRENCY=3

# LLM — choose one provider
LLM_PROVIDER=ollama
LLM_API_KEY=your-x-api-key
LLM_BASE_URL=https://ollama.siliconmango.in
LLM_MODEL=gemma4:31b

# Relevance & search
RELEVANCE_THRESHOLD=0.65
MAX_JOBS_DEFAULT=100
DRY_RUN=true

# Gmail IMAP (optional, for verification emails)
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_FOLDER=INBOX
GMAIL_VERIFICATION_SENDER=security-noreply@linkedin.com
GMAIL_POLL_INTERVAL=8
GMAIL_POLL_TIMEOUT=180

# Grants (LinkedIn posts) extraction
MAX_GRANT_POSTS_DEFAULT=10
MAX_POST_SEARCH_PAGES=5
GRANT_ANALYZE_IMAGES=true
GRANT_FOLLOW_LINKS=true
GRANT_MAX_LINKS_PER_POST=2
GRANT_MAX_IMAGES_PER_POST=2
GRANT_RELEVANCE_THRESHOLD=0.7

# Auth — hardcoded admin (users are managed by the admin in the web UI)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@tamuku.in
ADMIN_PASSWORD=TamukuAdmin@2026
SECRET_KEY=change-me-to-a-long-random-string

# Outbound mail (welcome emails; reuses the Gmail app password above)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
APP_BASE_URL=http://localhost:5000

# Flask
FLASK_DEBUG=false
PORT=5000
