# LinkedIn credentials
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# Playwright
PLAYWRIGHT_HEADLESS=true
MAX_DETAIL_CONCURRENCY=3

# LLM — choose one provider
LLM_PROVIDER=ollama
LLM_API_KEY=your-x-api-key
LLM_BASE_URL=https://ollama.siliconmango.in
LLM_MODEL=gemma4:31b

# Relevance & search
RELEVANCE_THRESHOLD=0.65
MAX_JOBS_DEFAULT=100
DRY_RUN=true

# Gmail IMAP (optional, for verification emails)
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_FOLDER=INBOX
GMAIL_VERIFICATION_SENDER=security-noreply@linkedin.com
GMAIL_POLL_INTERVAL=8
GMAIL_POLL_TIMEOUT=180

# Flask
FLASK_DEBUG=false
PORT=5000
